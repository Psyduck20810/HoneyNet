# ─────────────────────────────────────────
# HONEYPOT ENVIRONMENT VARIABLES
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/honeypot_db?appName=<appname>

# Telegram Bot Token
# Get from: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID
# Get from: https://t.me/userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# Gmail sender address and App Password (not your real Gmail password)
# Get app password from: Google Account → Security → 2-Step Verification → App passwords
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_RECEIVER=alerts_recipient@gmail.com

# Dashboard Basic Auth credentials (protect /dashboard and API routes)
DASHBOARD_USER=admin
DASHBOARD_PASS=change_me_to_a_strong_password

# Infura API Key for Ethereum Sepolia testnet blockchain logging
# Get from: https://app.infura.io → Create New API Key → Sepolia endpoint
# Leave empty to use the local blockchain fallback instead
INFURA_KEY=your_infura_project_id_here
